    {
      "name": "Post Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Test Suite\r",
              "pm.test(\"Validate courses and product structure\", function () {\r",
              "\r",
              "    // Check courses is array\r",
              "    pm.expect(jsonData.courses[0].products).to.be.an(\"array\");\r",
              "\r",
              "    // Check price is number\r",
              "    pm.expect(jsonData.courses[0].products[0].price).to.be.a(\"number\");\r",
              "\r",
              "    // Check inStock is boolean\r",
              "    pm.expect(jsonData.courses[0].products[0].inStock).to.be.a(\"boolean\");\r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "// Custom Logs (Visible in Postman Console)\r",
              "console.log(\"Courses:\", jsonData.courses);\r",
              "console.log(\"First Product:\", jsonData.courses[0].products[0]);\r",
              "console.log(\"Price:\", jsonData.courses[0].products[0].price);\r",
              "console.log(\"Stock Status:\", jsonData.courses[0].products[0].inStock);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
