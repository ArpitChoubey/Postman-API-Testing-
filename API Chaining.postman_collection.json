    {
      "name": "Delete Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.unset(\"userid\");\r",
              "pm.collectionVariables.unset(\"useremail\");\r",
              "pm.collectionVariables.unset(\"username\");\r",
              "\r",
              "pm.test(\"Response status code is 204\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(204);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Validate that the response body is empty for a successful DELETE request\", function () {\r",
              "    const responseData = xml2Json(pm.response.text());\r",
              "    \r",
              "    pm.expect(responseData).to.be.null;\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response has the correct Content-Type header\", function () {\r",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.eql('text/xml');\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Verify that the user ID is no longer present in the system after deletion\", function () {\r",
              "    const userId = \"{{userid}}\"; // replace with actual user id if needed\r",
              "    pm.sendRequest({\r",
              "        url: `https://gorest.co.in/public/v2/users/${userId}`,\r",
              "        method: 'GET'\r",
              "    }, function (err, res) {\r",
              "        pm.expect(res).to.have.property('status', 404); // Expecting a 404 Not Found status after deletion\r",
              "    });\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response status code is 204 for successful deletion\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(204);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response body should be empty for a successful DELETE request\", function () {\r",
              "    const responseData = xml2Json(pm.response.text());\r",
              "    \r",
              "    pm.expect(responseData).to.be.null;\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Content-Type header is correctly set to 'text/xml'\", function () {\r",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.equal('text/xml');\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"User ID should no longer exist in the system after deletion\", function () {\r",
              "    pm.sendRequest({\r",
              "        url: 'https://gorest.co.in/public/v2/users/' + pm.environment.get('userid'),\r",
              "        method: 'GET'\r",
              "    }, function (err, res) {\r",
              "        pm.expect(res).to.have.property('status', 404);\r",
              "    });\r",
              "});\r",
              "\r",
              ""
            ],
