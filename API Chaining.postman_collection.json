  "item": [
    {
      "name": "Post Request",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const text = Math.random().toString(36).substring(2);\r",
              "const email = text + \"@gmail.com\";\r",
              "\r",
              "console.log(email);\r",
              "\r",
              "pm.collectionVariables.set(\"username\", \"abcxyz\");\r",
              "pm.collectionVariables.set(\"useremail\", email);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "pm.collectionVariables.set(\"userid\", jsonData.id);\r",
              "\r",
              "pm.test(\"Response status code is 200\", function () {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    pm.expect(responseData).to.be.an('array');\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Validate the response schema against the expected structure\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    pm.expect(responseData).to.be.an('array');\r",
              "    responseData.forEach(user => {\r",
              "        pm.expect(user).to.be.an('object');\r",
              "        pm.expect(user).to.have.all.keys('id', 'name', 'email', 'gender', 'status');\r",
              "        pm.expect(user.id).to.be.a('number');\r",
              "        pm.expect(user.name).to.be.a('string').that.is.not.empty;\r",
              "        pm.expect(user.email).to.be.a('string').that.matches(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/, \"Email format is invalid\");\r",
              "        pm.expect(user.gender).to.be.oneOf(['male', 'female']);\r",
              "        pm.expect(user.status).to.be.oneOf(['active', 'inactive']);\r",
              "    });\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response contains no duplicate user entries\", function () {\r",
              "    const responseData = pm.response.json();\r",
              "    \r",
              "    pm.expect(responseData).to.be.an('array');\r",
              "    \r",
              "    const userIds = responseData.map(user => user.id);\r",
              "    const uniqueUserIds = new Set(userIds);\r",
              "    \r",
              "    pm.expect(uniqueUserIds.size).to.equal(userIds.length, \"There are duplicate user entries in the response\");\r",
              "});\r",
              "\r",
              "var template = `\r",
              "<canvas id=\"myChart\" height=\"75\"></canvas>\r",
              "\r",
              "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js\"></script> \r",
              "\r",
              "<script>\r",
              "    var ctx = document.getElementById(\"myChart\");\r",
              "\r",
              "    var myChart = new Chart(ctx, {\r",
              "        type: \"bar\",\r",
              "        data: {\r",
              "            labels: [],\r",
              "            datasets: [{\r",
              "                data: [],\r",
              "                \r",
              "                // Change these colours to customize the chart\r",
              "                backgroundColor: [\"#003f5c\", \"#58508d\", \"#bc5090\", \"#ff6361\", \"#ffa600\"],\r",
              "            }]\r",
              "        },\r",
              "        options: {\r",
              "            legend: { display: false },\r",
              "            title: {\r",
              "                display: true,\r",
              "                text: 'Count'\r",
              "            },\r",
              "            scales: {\r",
              "                xAxes: [{\r",
              "                    display: true,\r",
              "                    scaleLabel: {\r",
              "                        display: true,\r",
              "                        labelString: 'Items'\r",
              "                    }\r",
              "                }],\r",
              "                yAxes: [{\r",
              "                    display: true,\r",
              "                    scaleLabel: {\r",
              "                        display: true,\r",
              "                        labelString: 'Count'\r",
              "                    }\r",
              "                }]\r",
              "            }\r",
              "        }\r",
              "\r",
              "    });\r",
              "\r",
              "    // Access the data passed to pm.visualizer.set() from the JavaScript\r",
              "    pm.getData(function (err, value) {\r",
              "        myChart.data.datasets[0].data = value.response.data;\r",
              "        myChart.data.labels = value.response.labels;\r",
              "        myChart.update();\r",
              "    });\r",
              "\r",
              "</script>`;\r",
              "\r",
              "function constructVisualizerPayload() {\r",
              "    // Since the response is an empty array, we can set the labels and data to empty arrays.\r",
              "    var visualizerData = {\r",
              "        labels: [],\r",
              "        data: []\r",
              "    };\r",
              "\r",
              "    return {response: visualizerData};\r",
              "}\r",
              "\r",
              "pm.visualizer.set(template, constructVisualizerPayload());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
